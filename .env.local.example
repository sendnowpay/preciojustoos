# Supabase — get these from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Mercado Pago — get from developers.mercadopago.com
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-YOUR_PUBLIC_KEY
MP_ACCESS_TOKEN=APP_USR-YOUR_ACCESS_TOKEN

# App URL — your Vercel domain
NEXT_PUBLIC_APP_URL=https://preciojustoos.com
